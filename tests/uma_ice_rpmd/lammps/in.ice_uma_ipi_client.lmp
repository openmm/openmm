# LAMMPS i-PI client for UMA ice RPMD benchmark.
# i-PI drives dynamics; LAMMPS computes forces via fix external (UMA).
# Must be run via run_ipi_lammps_uma_rpmd.py (injects fix external callback).
#
# INET: localhost 65535 (match i-PI ffsocket mode=inet)
# Atom order must match init.xyz (shared_data.ice_uma or data.ice_uma)

units           metal
atom_style      atomic
boundary        p p p
read_data       data.ice_uma
comm_modify     cutoff 12.0

# No classical pair potential; UMA via fix external
pair_style      zero 1.0
pair_coeff      * *

# fix external is injected by run_ipi_lammps_uma_rpmd.py (fairchem UMA)
# fix ext all external pf/callback 1 1

# Connect to i-PI (inet). Run count must match i-PI total_steps.
fix             1 all ipi 127.0.0.1 65535
run             1000
