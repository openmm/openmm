# Pipeline 1 ps run: same as OpenMM (NVT Langevin tau=0.1 ps, 1 fs, 1000 steps).
#   thermo/dump every 10 steps (10 fs). Order post-process via lammps_order_from_dump.py.
#
# Build data:  python build_lammps_ice_data.py -n 128
# Run:         python run_lammps_uma_ice.py --infile in.ice_uma_pipeline_1ps.lmp
# Post-process: python lammps_order_from_dump.py --dump lammps/dump.pipeline_1ps.lammpstrj -o ice_order_uma_lammps.csv

units           metal
atom_style      atomic
boundary        p p p
read_data       data.ice_uma
comm_modify     cutoff 12.0
timestep        0.001

minimize        0.0 1.0e-6 500 150

velocity        all create 243.0 284759 dist gaussian
velocity        all scale 243.0
fix             nve all nve
fix             lang all langevin 243.0 243.0 0.1 284759 zero yes
thermo_style    custom step time temp pe ke etotal
thermo          10

dump            traj all custom 10 dump.pipeline_1ps.lammpstrj id type mass x y z
dump_modify     traj sort id flush yes
dump            ovito all xyz 10 dump.pipeline_1ps_ovito.xyz
dump_modify     ovito element O H sort id append yes
run             1000
