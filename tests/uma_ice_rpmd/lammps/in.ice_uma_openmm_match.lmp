# Matches OpenMM run_openmm_ice_lammps_match.py defaults (apples-to-apples):
#   data.ice_uma | minimize capped ~150 force evals | T=243 K | Langevin gamma=1/ps | dt=1 fs
#   velocity seed 284759 (same as OpenMM --seed) | Langevin seed 284759 | run 100 steps
#   dump every step (same as OpenMM --traj-every 1 + XYZ)
#
# Build data:  python build_lammps_ice_data.py -n 128
# Run:         python run_lammps_uma_ice.py --infile in.ice_uma_openmm_match.lmp --device cuda
#
# Pure speed test (no dump I/O): use in.ice_uma_openmm_match_notraj.lmp

units           metal
atom_style      atomic
boundary        p p p
read_data       data.ice_uma
comm_modify     cutoff 12.0
timestep        0.001

# OpenMM default --minimize-iters 150  → cap LAMMPS at 150 energy/force evaluations
minimize        0.0 1.0e-6 500 150

velocity        all create 243.0 284759 dist gaussian
velocity        all scale 243.0
fix             nve all nve
fix             lang all langevin 243.0 243.0 1.0 284759 zero yes
thermo_style    custom step time temp pe ke etotal
thermo          10

dump            traj all custom 1 dump.openmm_match.lammpstrj id type mass x y z
dump_modify     traj sort id flush yes
dump            ovito all xyz 1 dump.openmm_match_ovito.xyz
dump_modify     ovito element O H sort id append yes
run             100
